---

<Layout title="About" footer={false}>
  <div class="flex flex-col gap-3">
    fever
    <div>
      <p class="text-2xl">Silly dev that writes <span class="text-ctp-red">bad</span> code!</p>
      <p>I primarily use <Link href="https://github.com/kathund/nix-config" text="NixOS" /> and NeoVim.</p>
      <p>
        I'm <Link href="/time" text="UTC+8" external={false} /> so expect responses between <ResponseTime
          client:load
        />! (<ResponseTime user={true} client:load /> in <span class="text-ctp-red">your</span> timezone)
      </p>
      <p>
        If I do not respond <span class="text-bold underline">PLEASE</span> send a follow up message as I get very distracted!
      </p>
    </div>

    <div>
      <p class="text-xl">Languages:</p>
      <p>- TypeScript/JavaScript</p>
      <p>- Rust</p>
      <p>- Java/Kotlin</p>
    </div>

    <div class="flex flex-col">
      <p class="text-xl">Random things I know how to use:</p>
      {
        thingsIUse
          .sort((a, b) => a.text.localeCompare(b.text))
          .map(({ href, text }) => <Link href={href} text={`- ${text}`} />)
      }
    </div>

    <div class="flex flex-col">
      <p class="text-xl">Links:</p>
      <p>- Matrix: @kathund:snowball.kathund.dev</p>
      <p>- Matrix: @kathund:matrix.org (DEPRECATED and will not check)</p>
      <Link href="https://discord.com/users/1276524855445164098" text="- Discord: @.kathund (1276524855445164098)" />
      <Link href="https://ko-fi.com/kathund" text="- Ko-fi" />
      <Link href="https://github.com/Kathund" text="- GitHub: @kathund" />
    </div>
  </div>

  <Footer />
  <HorizontalSeparator />
  <div class="flex flex-row gap-2">
    <div class="flex flex-col gap-2">
      <div>
        <p>Cool people!</p>
        <p class="text-ctp-text/50 text-sm">If you ever looking for good devs please check them out</p>
      </div>
      <div class="flex flex-col gap-2">
        {
          coolPeople
            .sort((a, b) => a.name.localeCompare(b.name))
            .map((person) => (
              <Person
                client:load
                name={person.name}
                github={person.github}
                codeberg={person.codeberg}
                site={person.site}
                note={person.note}
                shouldRandomCase={person.shouldRandomCase}
              />
            ))
        }
      </div>
    </div>
    <VerticalSeparator />

    <div class="mr-8">
      <div class="grid h-fit grid-cols-1 gap-0 p-2 lg:grid-cols-3">
        {peopleButtons.map(({ alt, src, href }) => <Button client:load alt={alt} src={src} href={href} />)}
      </div>
      <HorizontalSeparator />
      <div class="grid h-fit grid-cols-1 gap-0 p-2 lg:grid-cols-3">
        {buttons.map(({ alt, src, href }) => <Button client:load alt={alt} src={src} href={href} />)}
      </div>
    </div>
  </div>
</Layout>
