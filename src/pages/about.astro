---
import HorizontalSeparator from '../components/HorizontalSeparator.svelte';
import VerticalSeparator from '../components/VerticalSeparator.svelte';
import Button, { type ButtonProps } from '../components/Button.svelte';
import Person, { type PersonProps } from '../components/Person.svelte';
import ResponseTime from '../components/Time/ResponseTime.svelte';
import Footer from '../components/Footer.svelte';
import Layout from '../layouts/Layout.astro';
import Link from '../components/Link.svelte';

export interface Thing {
  href: string;
  text: string;
}

